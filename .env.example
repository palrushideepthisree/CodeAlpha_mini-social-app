# Copy this file to .env and fill in your own values.
# Never commit your real .env file to GitHub.

# MongoDB Atlas connection string
# Example: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/mini-social-app?retryWrites=true&w=majority
MONGO_URI=your_mongodb_atlas_connection_string_here

# Any long random string, used to sign JWT tokens
JWT_SECRET=change_this_to_a_long_random_secret

# Port the server runs on (Render sets this automatically, 5000 is for local dev)
PORT=5000
